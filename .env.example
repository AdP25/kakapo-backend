# Required for real upstream calls (set your own key)
OPENAI_API_KEY=

# Optional overrides
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
DEFAULT_MODEL=gemini-flash-latest
MOCK_MODE=false

# Startup: pre-seed exact_cache with demo Q/A pairs
SEED_CACHE=false

# Auth (JWT) — use a long random string in production
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
