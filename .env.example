# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://kakapo:password@localhost:5432/kakapo

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI (embeddings + GPT-4o fallback)
OPENAI_API_KEY=sk-...

# Anthropic (primary LLM)
ANTHROPIC_API_KEY=sk-ant-...

# First-run seed: creates default tenant + admin API key on startup if DB is empty
INITIAL_ADMIN_KEY=change-me-to-a-long-random-string
INITIAL_TENANT_NAME=Default

# Environment
ENVIRONMENT=development
